{
  "name": "discord-calendar-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "deploy": "wrangler deploy src/worker.js --name discord-calendar --compatibility-date 2025-01-01",
    "dev":    "wrangler dev src/worker.js --name discord-calendar --compatibility-date 2025-01-01",
    "tail":   "wrangler tail --name discord-calendar"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
